{
  "name": "sql-to-pandas-translator",
  "version": "0.1.0",
  "private": true,
  "description": "A client-side web app that converts SQL queries into equivalent pandas Python code with per-clause explanations.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "node-sql-parser": "5.3.6",
    "prismjs": "1.29.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/prismjs": "1.26.4",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "fast-check": "3.23.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.6.3",
    "vite": "6.0.5",
    "vitest": "2.1.8"
  }
}
